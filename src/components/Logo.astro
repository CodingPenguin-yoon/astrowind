---
import { portfolioProfile } from '~/data/portfolio';
---

<span class="flex items-center gap-2 whitespace-nowrap text-slate-100">
  <span class="text-lg font-mono text-green-400">$</span>
  <span class="flex flex-col leading-none">
    <span class="font-heading text-[15px] tracking-[0.08em] md:text-sm">{portfolioProfile.name}</span>
    <span class="mt-1 font-heading text-[10px] uppercase tracking-[0.22em] text-slate-400">{portfolioProfile.nameEn}</span>
  </span>
  <span class="inline-block h-5 w-2 bg-green-400 terminal-cursor"></span>
</span>
