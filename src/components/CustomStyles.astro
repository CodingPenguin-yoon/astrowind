---
import '@fontsource/ibm-plex-sans-kr/400.css';
import '@fontsource/ibm-plex-sans-kr/500.css';
import '@fontsource/ibm-plex-sans-kr/600.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
---

<style is:inline>
  @font-face {
    font-family: 'DungGeunMo';
    src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/noonfonts_six@1.2/DungGeunMo.woff') format('woff');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --aw-font-sans: 'IBM Plex Sans KR';
    --aw-font-serif: 'IBM Plex Sans KR';
    --aw-font-heading: 'DungGeunMo';
    --aw-font-mono: 'IBM Plex Mono', monospace;

    /* Terminal green/cyan accent */
    --aw-color-primary: rgb(34 197 94);
    --aw-color-secondary: rgb(22 163 74);
    --aw-color-accent: rgb(6 182 212);

    /* Dark background */
    --aw-color-bg-page: rgb(15 23 42);
    --aw-color-bg-page-dark: rgb(30 41 59);

    /* Light text */
    --aw-color-text-heading: rgb(248 250 252);
    --aw-color-text-default: rgb(226 232 240);
    --aw-color-text-muted: rgb(148 163 184);

    ::selection {
      background-color: rgb(34 197 94 / 0.3);
      color: rgb(248 250 252);
    }
  }

  html {
    background-color: rgb(15 23 42);
  }

  body {
    background:
      radial-gradient(ellipse at top, rgb(30 41 59 / 0.8), transparent 50%),
      radial-gradient(circle at 80% 20%, rgb(6 182 212 / 0.1), transparent 30%),
      linear-gradient(180deg, rgb(15 23 42) 0%, rgb(30 41 59) 100%);
    font-family: var(--aw-font-sans), sans-serif;
    min-height: 100vh;
  }

  .dark {
    --aw-font-sans: 'IBM Plex Sans KR';
    --aw-font-serif: 'IBM Plex Sans KR';
    --aw-font-heading: 'DungGeunMo';
    --aw-font-mono: 'IBM Plex Mono', monospace;

    /* Terminal green/cyan accent */
    --aw-color-primary: rgb(34 197 94);
    --aw-color-secondary: rgb(22 163 74);
    --aw-color-accent: rgb(6 182 212);

    /* Dark background */
    --aw-color-bg-page: rgb(15 23 42);
    --aw-color-bg-page-dark: rgb(30 41 59);

    /* Light text */
    --aw-color-text-heading: rgb(248 250 252);
    --aw-color-text-default: rgb(226 232 240);
    --aw-color-text-muted: rgb(148 163 184);

    ::selection {
      background-color: rgb(34 197 94 / 0.3);
      color: rgb(248 250 252);
    }
  }

  /* Terminal cursor blink animation */
  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  .terminal-cursor {
    animation: blink 1s step-end infinite;
  }

  h1,
  h2,
  h3,
  .font-heading {
    letter-spacing: 0.01em;
  }
</style>
