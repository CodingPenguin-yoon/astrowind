---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import {
  focusAreas,
  heroTags,
  portfolioProfile,
  profilePoints,
  snapshotItems,
  selectedProjects,
  toolkit,
  type PortfolioProject,
  experienceTimeline,
} from '~/data/portfolio';
import type { CallToAction as CallToActionType } from '~/types';

const metadata = {
  title: `${portfolioProfile.name} | 운영 자동화 · 플랫폼 포트폴리오`,
  description: portfolioProfile.intro,
  ignoreTitleTemplate: true,
};

const headerLinks = [
  { text: '소개', href: '#about' },
  { text: '대표 프로젝트', href: '#projects' },
  { text: '핵심 역량', href: '#focus' },
  { text: '설계 원칙', href: '#experience' },
  { text: '연락하기', href: '#contact' },
];

const visibleSocials = [
  { label: 'GitHub', href: portfolioProfile.socials.github },
  { label: 'LinkedIn', href: portfolioProfile.socials.linkedin },
  { label: 'Blog', href: portfolioProfile.socials.blog },
].filter(({ href }) => href);

const withExternalTarget = (href: string) => (href.startsWith('http') ? { target: '_blank' as const } : {});

const heroActions: CallToActionType[] = [{ variant: 'primary', text: '대표 프로젝트 보기', href: '#projects' }];

if (portfolioProfile.socials.github) {
  heroActions.push({
    variant: 'secondary',
    text: 'GitHub 보기',
    href: portfolioProfile.socials.github,
    ...withExternalTarget(portfolioProfile.socials.github),
  });
}

const heroPanel = `
  <div class="relative overflow-hidden rounded-lg border border-slate-700/80 bg-slate-900/95 shadow-2xl shadow-green-500/10 font-mono">
    <div class="flex items-center gap-2 border-b border-slate-700/50 bg-slate-800/80 px-4 py-3">
      <div class="flex gap-1.5">
        <span class="h-3 w-3 rounded-full bg-red-500/80"></span>
        <span class="h-3 w-3 rounded-full bg-yellow-500/80"></span>
        <span class="h-3 w-3 rounded-full bg-green-500/80"></span>
      </div>
      <span class="ml-2 text-xs text-slate-400">~/portfolio</span>
    </div>

    <div class="space-y-5 p-5 text-sm">
      <div>
        <span class="text-green-400">$</span>
        <span class="ml-2 text-cyan-300">whoami</span>
        <p class="mt-2 ml-4 text-slate-200">운영 자동화 · 플랫폼 엔지니어</p>
      </div>

      <div>
        <span class="text-green-400">$</span>
        <span class="ml-2 text-cyan-300">cat focus.txt</span>
        <div class="mt-2 ml-4 space-y-1 text-slate-300">
          <p><span class="mr-2 text-green-400">▸</span>자연어 명령</p>
          <p><span class="mr-2 text-green-400">▸</span>인프라 워크플로우</p>
          <p><span class="mr-2 text-green-400">▸</span>질문 중심 정보 구조</p>
        </div>
      </div>

      <div>
        <span class="text-green-400">$</span>
        <span class="ml-2 text-cyan-300">ls projects/</span>
        <div class="mt-2 ml-4 space-y-1 text-slate-300">
          <p>K-Le-PaaS</p>
          <p>Heimdall</p>
          <p>Argus</p>
        </div>
      </div>

      <div class="flex items-center pt-1">
        <span class="text-green-400">$</span>
        <span class="ml-2 inline-block h-4 w-2 bg-green-400 terminal-cursor"></span>
      </div>
    </div>
  </div>
`;

const profilePanel = `
  <div class="relative overflow-hidden rounded-lg border border-slate-700/80 bg-slate-900/95 shadow-2xl shadow-cyan-500/10">
    <div class="flex items-center gap-2 border-b border-slate-700/50 bg-slate-800/80 px-4 py-3 font-mono">
      <div class="flex gap-1.5">
        <span class="h-3 w-3 rounded-full bg-red-500/80"></span>
        <span class="h-3 w-3 rounded-full bg-yellow-500/80"></span>
        <span class="h-3 w-3 rounded-full bg-green-500/80"></span>
      </div>
      <span class="ml-2 text-xs text-slate-400">project-map.txt</span>
    </div>

    <div class="space-y-4 p-5">
      ${snapshotItems
        .map(
          ({ title, description }) => `
            <div class="rounded-xl border border-slate-700/60 bg-slate-800/40 p-4">
              <p class="text-[11px] font-mono uppercase tracking-[0.18em] text-slate-500">${title}</p>
              <p class="mt-2 text-sm leading-relaxed text-slate-200">${description}</p>
            </div>
          `
        )
        .join('')}

      ${
        visibleSocials.length
          ? `
            <div class="rounded-xl border border-slate-700/60 bg-slate-800/40 p-4">
              <p class="text-[11px] font-mono uppercase tracking-[0.18em] text-slate-500">Links</p>
              <div class="mt-3 flex flex-wrap gap-2">
                ${visibleSocials
                  .map(
                    ({ label, href }) => `
                      <a
                        class="rounded-full border border-slate-600/60 bg-slate-900/70 px-3 py-1 text-xs font-mono text-cyan-300 transition hover:border-green-500/50 hover:text-green-400"
                        href="${href}"
                        ${href.startsWith('http') ? 'target="_blank" rel="noopener noreferrer"' : ''}
                      >
                        ${label}
                      </a>
                    `
                  )
                  .join('')}
              </div>
            </div>
          `
          : ''
      }
    </div>
  </div>
`;

const buildProjectPanel = (project: PortfolioProject) => `
  <div class="group relative overflow-hidden rounded-lg border border-slate-700/80 bg-slate-900/95 shadow-2xl shadow-cyan-500/10 transition-all duration-300 hover:border-green-500/40 hover:shadow-green-500/15">
    <div class="flex items-center justify-between border-b border-slate-700/50 bg-gradient-to-r from-slate-800/80 to-slate-800/40 px-5 py-4">
      <span class="text-xs font-mono uppercase tracking-wider text-green-400">${project.kicker}</span>
      <span class="rounded-full border border-slate-600/50 bg-slate-800 px-3 py-1 text-xs font-mono text-cyan-300">${project.meta}</span>
    </div>

    <div class="p-6">
      <h3 class="text-2xl font-bold text-slate-100 transition-colors group-hover:text-green-400">${project.title}</h3>
      <p class="mt-3 text-sm leading-relaxed text-slate-300/85">${project.summary}</p>

      <div class="mt-6 grid gap-3">
        ${project.panelPoints
          .map(
            (point) => `
              <div class="rounded-xl border ${
                point.tone === 'roadmap'
                  ? 'border-cyan-500/30 bg-cyan-950/20'
                  : 'border-slate-700/60 bg-slate-800/40'
              } p-4">
                <p class="text-xs font-mono uppercase tracking-[0.18em] ${
                  point.tone === 'roadmap' ? 'text-cyan-300' : 'text-slate-500'
                }">${point.label}</p>
                <p class="mt-2 text-sm leading-relaxed ${
                  point.tone === 'roadmap' ? 'text-cyan-100/90' : 'text-slate-200'
                }">${point.value}</p>
              </div>
            `
          )
          .join('')}
      </div>

      <div class="mt-6 flex flex-wrap gap-2">
        ${project.stack
          .map(
            (item) => `
              <span class="rounded-full border border-slate-600/50 bg-slate-800 px-3 py-1 text-xs font-mono text-cyan-300 transition hover:border-green-500/50 hover:text-green-400">${item}</span>
            `
          )
          .join('')}
      </div>
    </div>
  </div>
`;

const contactActions: CallToActionType[] = [];

if (portfolioProfile.socials.github) {
  contactActions.push({
    variant: 'primary',
    text: 'GitHub',
    href: portfolioProfile.socials.github,
    ...withExternalTarget(portfolioProfile.socials.github),
  });
}

if (portfolioProfile.resumeHref) {
  contactActions.push({
    variant: 'secondary',
    text: '이력서',
    href: portfolioProfile.resumeHref,
    ...withExternalTarget(portfolioProfile.resumeHref),
  });
}

if (portfolioProfile.email) {
  contactActions.push({
    variant: 'secondary',
    text: '연락하기',
    href: `mailto:${portfolioProfile.email}`,
  });
}

if (!contactActions.length && portfolioProfile.socials.blog) {
  contactActions.push({
    variant: 'primary',
    text: '작업 기록',
    href: portfolioProfile.socials.blog,
  });
}
---

<Layout metadata={metadata}>
  <Fragment slot="announcement"></Fragment>
  <Fragment slot="header">
    <Header links={headerLinks} actions={[{ text: '연락하기', href: '#contact' }]} isSticky />
  </Fragment>

  <Hero image={heroPanel} actions={heroActions}>
    <Fragment slot="title">
      {portfolioProfile.name}
      <span class="mt-3 block font-heading text-sm uppercase tracking-[0.24em] text-slate-400 md:text-base">
        {portfolioProfile.nameEn}
      </span>
      <span class="mt-5 block text-accent">{portfolioProfile.role}</span>
    </Fragment>

    <Fragment slot="subtitle">{portfolioProfile.intro}</Fragment>

    <Fragment slot="content">
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3 text-sm text-muted">
        {
          heroTags.map((tag) => (
            <span class="rounded-md border border-slate-700/50 bg-slate-800/80 px-4 py-2 font-mono tracking-[0.04em]">
              {tag}
            </span>
          ))
        }
      </div>
    </Fragment>

    <Fragment slot="bg">
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(34,197,94,0.15),transparent_50%),radial-gradient(circle_at_80%_20%,rgba(6,182,212,0.1),transparent_30%)]"
      >
      </div>
    </Fragment>
  </Hero>

  <Content
    id="about"
    title="복잡한 작업을 제어 가능한 흐름으로 바꿉니다"
    subtitle={portfolioProfile.summary}
    image={profilePanel}
    items={profilePoints}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-[linear-gradient(180deg,transparent,rgba(30,41,59,0.5))]"></div>
    </Fragment>

    <Fragment slot="content">
      <p class="leading-relaxed text-slate-300/85">
        세 프로젝트는 각각 운영 제어, 인프라 워크플로우, 질문 중심 정보 구조를 다루지만, 공통적으로 복잡한 입력과
        상태를 사람이 다시 사용할 수 있는 흐름으로 정리하는 데 초점을 둡니다.
      </p>
    </Fragment>
  </Content>

  {
    selectedProjects.map((project, index) => (
      <Content
        id={index === 0 ? 'projects' : undefined}
        isReversed={index % 2 === 1}
        isAfterContent={index > 0}
        title={index === 0 ? '대표 프로젝트' : undefined}
        subtitle={index === 0 ? '한 줄 요약, 직접 구현한 범위, 설계 포인트, 프로젝트 의의 기준으로 정리했습니다.' : undefined}
        image={buildProjectPanel(project)}
        items={[
          { title: project.implementationLabel, description: project.implementation },
          { title: '설계 포인트', description: project.designPoint },
          { title: project.significanceLabel, description: project.significance },
        ]}
      >
        <Fragment slot="content">
          <p class="font-mono text-sm font-semibold uppercase tracking-[0.24em] text-green-400">{project.kicker}</p>
          <h3 class="mt-3 text-3xl font-bold tracking-tight text-slate-100 sm:text-4xl">{project.title}</h3>
          <p class="mt-4 leading-relaxed text-slate-300/85">{project.summary}</p>

          <div class="mt-5 flex flex-wrap gap-2">
            <span class="rounded-full border border-slate-700/60 bg-slate-800/60 px-3 py-1 text-xs font-mono text-cyan-300">
              {project.meta}
            </span>
            {project.significanceLabel === '로드맵' && (
              <span class="rounded-full border border-cyan-500/30 bg-cyan-950/20 px-3 py-1 text-xs font-mono text-cyan-200">
                현재 구현 / 로드맵 분리
              </span>
            )}
          </div>
        </Fragment>
      </Content>
    ))
  }

  <Features3
    id="focus"
    tagline="Capability"
    title="핵심 역량"
    subtitle="운영 자동화, 인프라 워크플로우, 질문 중심 정보 구조 설계에 맞춰 현재 작업 범위를 정리했습니다."
    columns={3}
    defaultIcon="tabler:square-rounded-check-filled"
    items={focusAreas}
    classes={{
      headline: {
        subtitle: 'mx-auto max-w-3xl text-xl text-slate-300/80',
      },
      items: {
        title: 'text-lg font-semibold text-slate-100',
        description: 'text-slate-300/75 leading-relaxed',
      },
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(6,182,212,0.08),transparent_45%)]"></div>
    </Fragment>
  </Features3>

  <Steps
    id="experience"
    title="설계 원칙"
    subtitle="프로젝트마다 대상은 달라도 아래 원칙은 공통으로 적용합니다."
    items={experienceTimeline}
    classes={{
      container: 'max-w-4xl',
      headline: {
        subtitle: 'text-slate-300/80',
      },
      items: {
        title: 'text-slate-100',
        description: 'text-slate-300/75 leading-relaxed',
      },
    }}
  />

  <Features3
    id="toolkit"
    title="기술"
    subtitle="기술은 일반론보다 각 프로젝트와 연결해서 정리했습니다."
    columns={3}
    defaultIcon="tabler:point-filled"
    items={toolkit}
    classes={{
      headline: {
        subtitle: 'mx-auto max-w-3xl text-xl text-slate-300/80',
      },
      items: {
        title: 'text-lg font-semibold text-slate-100',
        description: 'text-slate-300/75 leading-relaxed',
      },
    }}
  />

  <CallToAction
    id="contact"
    title="이런 문제를 함께 풀 수 있습니다"
    subtitle="운영 자동화 백엔드, 인프라 provisioning 워크플로우, 배포·롤백·모니터링 통합, 질문 중심 정보 구조 설계를 다룹니다."
    actions={contactActions}
  >
    <Fragment slot="bg">
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(34,197,94,0.12),transparent_50%),radial-gradient(circle_at_bottom_right,rgba(6,182,212,0.1),transparent_40%)]"
      >
      </div>
    </Fragment>
  </CallToAction>
</Layout>
